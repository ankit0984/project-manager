*.log
combined.log
app-error.log

# Environment files (inject at runtime, not bake into image)
.env

# Dev tooling
.vscode
.idea
.DS_Store

# Testing
coverage
test-results
playwright-report
blob-report
playwright/.cache
playwright/.auth

# Git / CI
.git
.gitignore

# Misc
.devctx
*.pem
*.http
todo.js
